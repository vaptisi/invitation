(function(){
  function animateIn(){
    document.getElementById('t1').classList.add('vis');
    var subs = document.querySelectorAll('.info-sub');
    for(var k = 0; k < subs.length; k++){
      subs[k].classList.add('vis');
    }
    var paras = document.querySelectorAll('.info-para');
    for(var i = 0; i < paras.length; i++){
      (function(el, idx){
        setTimeout(function(){ el.classList.add('vis'); }, 200 + idx * 150);
      })(paras[i], i);
    }
    var div = document.querySelector('.divider');
    if(div) setTimeout(function(){ div.classList.add('vis'); }, 200 + paras.length * 150);
    var notes = document.querySelectorAll('.footnote');
    for(var j = 0; j < notes.length; j++){
      (function(el, idx){
        setTimeout(function(){ el.classList.add('vis'); }, 350 + paras.length * 150 + idx * 130);
      })(notes[j], j);
    }
    var baseDelay = 500 + paras.length * 150 + notes.length * 130;
    var pdfWrap = document.getElementById('pdfWrap');
    if(pdfWrap) setTimeout(function(){ pdfWrap.classList.add('vis'); }, baseDelay);
    var btns = document.getElementById('btns');
    if(btns) setTimeout(function(){ btns.classList.add('vis'); }, baseDelay + 150);
  }
  if(document.readyState === 'complete' || document.readyState === 'interactive'){
    setTimeout(animateIn, 100);
  } else {
    window.addEventListener('DOMContentLoaded', function(){ setTimeout(animateIn, 100); });
  }
})();
</script>
